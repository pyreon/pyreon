{
  "name": "@pyreon/ui-core",
  "version": "0.24.2",
  "description": "Core utilities, config, and context for Pyreon UI System",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon",
    "directory": "packages/ui-system/ui-core"
  },
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/analysis",
    "README.md",
    "LICENSE",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run vl_rolldown_build",
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@pyreon/manifest": "workspace:*",
    "@pyreon/typescript": "workspace:^",
    "@vitus-labs/tools-rolldown": "^2.4.0"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/styler": "workspace:^",
    "@pyreon/unistyle": "workspace:^"
  }
}
