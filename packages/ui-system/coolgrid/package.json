{
  "name": "@pyreon/coolgrid",
  "version": "0.11.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon",
    "directory": "packages/ui-system/coolgrid"
  },
  "description": "Responsive grid system for Pyreon",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/analysis",
    "README.md",
    "LICENSE",
    "src"
  ],
  "engines": {
    "node": ">= 22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublish": "bun run build",
    "build": "bun run vl_rolldown_build",
    "build:watch": "bun run vl_rolldown_build-watch",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/ui-core": "workspace:^",
    "@pyreon/unistyle": "workspace:^",
    "@pyreon/styler": "workspace:^"
  },
  "devDependencies": {
    "@vitus-labs/tools-rolldown": "^1.15.3",
    "@pyreon/typescript": "workspace:^"
  }
}
