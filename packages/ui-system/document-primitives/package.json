{
  "name": "@pyreon/document-primitives",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/ui-system",
    "directory": "packages/ui-system/document-primitives"
  },
  "description": "Rocketstyle document components \u2014 render in browser, export to 18 formats",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "bun": "./src/index.ts",
    "source": "./src/index.ts",
    "import": "./lib/index.js",
    "types": "./lib/index.d.ts"
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/analysis",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">= 22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublish": "bun run build",
    "build": "bun run vl_rolldown_build",
    "build:watch": "bun run vl_rolldown_build-watch",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/document": "workspace:^",
    "@pyreon/elements": "workspace:^",
    "@pyreon/rocketstyle": "workspace:^",
    "@pyreon/styler": "workspace:^",
    "@pyreon/ui-core": "workspace:^"
  },
  "dependencies": {
    "@pyreon/connector-document": "workspace:*"
  },
  "devDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/elements": "workspace:*",
    "@pyreon/rocketstyle": "workspace:*",
    "@pyreon/styler": "workspace:*",
    "@pyreon/ui-core": "workspace:*",
    "@vitus-labs/tools-rolldown": "^1.15.4",
    "@pyreon/typescript": "workspace:^"
  }
}
