{
  "name": "@pyreon/vitest-config",
  "version": "0.13.3",
  "private": true,
  "description": "Internal vitest config helpers — single canonical defineNodeConfig / defineBrowserConfig for every Pyreon package",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./internals": {
      "bun": "./src/internals.ts",
      "import": "./src/internals.ts",
      "types": "./src/internals.ts"
    }
  },
  "scripts": {
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "@vitus-labs/tools-vitest": "^2.5.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "*",
    "vitest": "*"
  },
  "peerDependenciesMeta": {
    "@vitest/coverage-v8": {
      "optional": true
    }
  }
}
