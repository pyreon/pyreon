{
  "name": "@pyreon/test-utils",
  "version": "0.13.34",
  "private": true,
  "description": "Internal testing utilities for Pyreon UI system components",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./browser": {
      "bun": "./src/browser/index.ts",
      "import": "./src/browser/index.ts",
      "types": "./src/browser/index.ts"
    },
    "./globals": {
      "types": "./src/globals.d.ts"
    }
  },
  "scripts": {
    "lint": "oxlint .",
    "test": "vitest run",
    "test:browser": "vitest run --config ./vitest.browser.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/rocketstyle": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/ui-core": "workspace:^"
  },
  "devDependencies": {
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.10"
  }
}
