{
  "name": "@pyreon/model",
  "version": "0.1.0",
  "description": "Structured reactive state — Zustand simplicity with MST-style typed API",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/pyreon/pyreon.git", "directory": "packages/model" },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/model#readme",
  "bugs": { "url": "https://github.com/pyreon/pyreon/issues" },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --sourcemap --external @pyreon/reactivity",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pyreon/reactivity": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
