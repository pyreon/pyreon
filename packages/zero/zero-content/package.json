{
  "name": "@pyreon/zero-content",
  "version": "0.37.1",
  "description": "Pyreon Zero \u2014 content layer for markdown-driven Pyreon sites. Compile-time .md/.mdx \u2192 Pyreon JSX, typed content collections (zod), convention-scanned MDX components.",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/zero/zero-content#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/zero/zero-content"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./plugin": {
      "bun": "./src/plugin.ts",
      "import": "./lib/plugin.js",
      "types": "./lib/types/plugin.d.ts"
    },
    "./schema": {
      "bun": "./src/schema.ts",
      "import": "./lib/schema.js",
      "types": "./lib/types/schema.d.ts"
    }
  },
  "files": [
    "lib",
    "!lib/analysis",
    "src",
    "!src/tests",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "test:browser": "vitest run --config ./vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/zero": "workspace:^"
  },
  "dependencies": {
    "@pyreon/head": "workspace:^",
    "@pyreon/router": "workspace:^",
    "esbuild": "^0.28.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "minisearch": "^7.1.0",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx": "^3.1.0",
    "remark-parse": "^11.0.0",
    "shiki": "^4.3.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@pyreon/manifest": "workspace:*",
    "@pyreon/test-utils": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "@types/mdast": "^4.0.4",
    "@vitest/browser-playwright": "^4.1.8",
    "mdast-util-directive": "^3.0.0",
    "mdast-util-mdx-jsx": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Vit Bokisch"
}
