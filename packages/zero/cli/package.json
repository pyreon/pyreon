{
  "name": "@pyreon/zero-cli",
  "version": "0.45.0",
  "description": "CLI for Pyreon Zero — dev, build, preview",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/zero/cli#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
