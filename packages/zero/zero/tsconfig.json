{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": true,
    "declarationDir": "./lib/types",
    "emitDeclarationOnly": true,
    "types": ["node", "vitest/globals"],
    "jsx": "react-jsx"
  },
  "include": ["src"],
  // image-types.ts is an ambient-only `declare module` source. The repo
  // tsconfig sets moduleDetection:force → every .ts is a module, so
  // `declare module '*.svg?raw'` would be read as an augmentation of a
  // non-existent module (TS2664). It carries no logic; vl_rolldown_build
  // emits it verbatim to lib/types/image-types.d.ts (a real .d.ts —
  // always ambient + moduleDetection-exempt for consumers). Correctness
  // is covered by the build's DTS emit + image-types-export.test.ts.
  "exclude": ["src/tests", "src/image-types.ts"]
}
