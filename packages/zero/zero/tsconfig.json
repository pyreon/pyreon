{
  "extends": "@pyreon/tsconfig/lib-jsx.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationDir": "./lib/types",
    "emitDeclarationOnly": true
  },
  // image-types.ts + font-types.ts are ambient-only `declare module`
  // sources. The repo tsconfig sets moduleDetection:force → every .ts
  // is a module, so `declare module '*.svg?raw'` / `*.woff2?font` would
  // be read as augmentations of non-existent modules (TS2664). They
  // carry no logic; vl_rolldown_build emits each verbatim to its
  // lib/types/*.d.ts (a real .d.ts — always ambient +
  // moduleDetection-exempt for consumers). Correctness is covered by
  // the build's DTS emit + the export tests.
  "exclude": ["src/tests", "src/image-types.ts", "src/font-types.ts"]
}
