{
  "name": "@pyreon/react-compat",
  "version": "0.5.6",
  "description": "React-compatible API shim for Pyreon — write React-style hooks that run on Pyreon's reactive engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/react-compat"
  },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/react-compat#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./dom": {
      "bun": "./src/dom.ts",
      "import": "./lib/dom.js",
      "types": "./lib/types/dom.d.ts"
    },
    "./jsx-runtime": {
      "bun": "./src/jsx-runtime.ts",
      "import": "./lib/jsx-runtime.js",
      "types": "./lib/types/jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "bun": "./src/jsx-runtime.ts",
      "import": "./lib/jsx-runtime.js",
      "types": "./lib/types/jsx-runtime.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "happy-dom": "^20.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
