{
  "name": "@pyreon/ui-components",
  "version": "0.15.6",
  "private": true,
  "description": "Pyreon UI component library — 58 production-ready rocketstyle components",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/ui/components"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "echo 'private package — consumed via bun condition'",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "test:browser": "vitest run --config ./vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@pyreon/coolgrid": "workspace:^",
    "@pyreon/core": "workspace:^",
    "@pyreon/elements": "workspace:^",
    "@pyreon/hooks": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/rocketstyle": "workspace:^",
    "@pyreon/styler": "workspace:^",
    "@pyreon/ui-core": "workspace:^",
    "@pyreon/ui-primitives": "workspace:^",
    "@pyreon/ui-theme": "workspace:^",
    "@pyreon/unistyle": "workspace:^"
  },
  "devDependencies": {
    "@pyreon/test-utils": "workspace:^",
    "@pyreon/typescript": "workspace:^",
    "@vitest/browser-playwright": "^4.1.4"
  }
}
