{
  "name": "@pyreon/ui-primitives",
  "version": "0.13.0",
  "private": true,
  "description": "Headless base components for the Pyreon UI library — state management, ARIA, keyboard nav",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/ui/primitives"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
