{
  "name": "@pyreon/ui-theme",
  "version": "0.13.1",
  "private": true,
  "description": "Default theme for the Pyreon UI component library",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/ui/theme"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
