    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@pyreon/rocketstyle": "workspace:^",
    "@pyreon/unistyle": "workspace:^"
  },
  "devDependencies": {
    "@pyreon/typescript": "workspace:^"
  }
}
