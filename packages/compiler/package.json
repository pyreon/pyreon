{
  "name": "@pyreon/compiler",
  "version": "0.1.0",
  "description": "Template and JSX compiler for Pyreon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/compiler#readme",
  "bugs": { "url": "https://github.com/pyreon/pyreon/issues" },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --packages external",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --watch --packages external",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
