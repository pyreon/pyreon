{
  "name": "@pyreon/native-compiler",
  "version": "0.2.0",
  "private": true,
  "description": "PRIVATE / EXPERIMENTAL — Pyreon Multi-Target Compiler (PMTC). Transforms Pyreon JSX source to native Swift (SwiftUI) and Kotlin (Jetpack Compose). Not published. See .claude/plans/native-platforms.md for strategic direction.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "coverage": "bun scripts/coverage-gate.ts",
    "coverage:gate": "bun scripts/coverage-gate.ts --gate",
    "coverage:swiftc": "bun scripts/coverage-gate.ts --swiftc-validate"
  },
  "dependencies": {
    "oxc-parser": "^0.133.0"
  },
  "devDependencies": {
    "@pyreon/vitest-config": "workspace:*",
    "vitest": "^4.1.8"
  }
}
