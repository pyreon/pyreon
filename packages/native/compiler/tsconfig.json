{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src"],
  // Fixtures are Pyreon JSX source strings the compiler PARSES, not
  // source files we type-check. They reference Pyreon framework globals
  // (`signal`, `<For>`, `<Show>`, `<Text>`, `<Button>`) that don't exist
  // in this package's dep graph. Exclude them from tsc.
  "exclude": ["src/fixtures"]
}
