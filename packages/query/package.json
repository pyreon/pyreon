{
  "name": "@pyreon/query",
  "version": "0.0.1",
  "description": "Pyreon adapter for TanStack Query",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --sourcemap --external @pyreon/core --external @pyreon/reactivity --external @tanstack/query-core",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@tanstack/query-core": "^5.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@pyreon/runtime-dom": "workspace:*",
    "typescript": "^5.5.0"
  }
}
