{
  "name": "@pyreon/compiler",
  "version": "0.43.0",
  "description": "Template and JSX compiler for Pyreon",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/core/compiler#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/core/compiler"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./diagnose": {
      "bun": "./src/diagnose.ts",
      "import": "./lib/diagnose.js",
      "types": "./lib/types/diagnose.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "build:native": "bun scripts/build-native.ts",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.138.0",
    "typescript": ">=5.0.0 <7.0.0"
  },
  "devDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/test-utils": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "happy-dom": "^20.9.0"
  },
  "optionalDependencies": {
    "@pyreon/compiler-darwin-arm64": "workspace:^",
    "@pyreon/compiler-darwin-x64": "workspace:^",
    "@pyreon/compiler-linux-arm64-gnu": "workspace:^",
    "@pyreon/compiler-linux-arm64-musl": "workspace:^",
    "@pyreon/compiler-linux-x64-gnu": "workspace:^",
    "@pyreon/compiler-linux-x64-musl": "workspace:^",
    "@pyreon/compiler-win32-x64-msvc": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
