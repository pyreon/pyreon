{
  "name": "@pyreon/runtime-dom",
  "version": "1.0.0",
  "description": "DOM renderer for Pyreon",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/runtime-dom#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/core/runtime-dom"
  },
  "files": [
    "lib",
    "!lib/**/*.map",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./transition": {
      "bun": "./src/transition-entry.ts",
      "import": "./lib/transition-entry.js",
      "types": "./lib/types/transition-entry.d.ts"
    },
    "./keep-alive": {
      "bun": "./src/keep-alive-entry.ts",
      "import": "./lib/keep-alive-entry.js",
      "types": "./lib/types/keep-alive-entry.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "test:browser": "vitest run --config ./vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@pyreon/compiler": "workspace:^",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/runtime-server": "workspace:^",
    "@pyreon/test-utils": "workspace:^",
    "@vitest/browser-playwright": "^4.1.4",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.8.3",
    "rolldown": "^1.0.0-rc.15",
    "vite": "^8.0.8"
  }
}
