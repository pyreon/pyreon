{
  "name": "@pyreon/reactivity",
  "version": "0.41.1",
  "description": "Signals-based reactivity system for Pyreon",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/core/reactivity#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/core/reactivity"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./lpih": {
      "bun": "./src/lpih.ts",
      "import": "./lib/lpih.js",
      "types": "./lib/types/lpih.d.ts"
    },
    "./coverage": {
      "bun": "./src/coverage.ts",
      "import": "./lib/coverage.js",
      "types": "./lib/types/coverage.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@pyreon/manifest": "workspace:*",
    "@pyreon/test-utils": "workspace:^",
    "@pyreon/vitest-config": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
