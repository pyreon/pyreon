{
  "name": "@pyreon/head",
  "version": "0.11.5",
  "description": "Head tag management for Pyreon \u2014 works in SSR and CSR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/core/head"
  },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/head#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./provider": {
      "bun": "./src/provider.ts",
      "import": "./lib/provider.js",
      "types": "./lib/types/provider.d.ts"
    },
    "./use-head": {
      "bun": "./src/use-head.ts",
      "import": "./lib/use-head.js",
      "types": "./lib/types/use-head.d.ts"
    },
    "./ssr": {
      "bun": "./src/ssr.ts",
      "import": "./lib/ssr.js",
      "types": "./lib/types/ssr.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "peerDependencies": {
    "@pyreon/runtime-server": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@pyreon/runtime-server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/runtime-server": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
