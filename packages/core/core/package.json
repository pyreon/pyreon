{
  "name": "@pyreon/core",
  "version": "0.39.0",
  "description": "Core component model and lifecycle for Pyreon",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/core/core#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/core/core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./jsx-runtime": {
      "bun": "./src/jsx-runtime.ts",
      "import": "./lib/jsx-runtime.js",
      "types": "./lib/types/jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "bun": "./src/jsx-dev-runtime.ts",
      "import": "./lib/jsx-dev-runtime.js",
      "types": "./lib/types/jsx-dev-runtime.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@pyreon/reactivity": "workspace:^"
  },
  "devDependencies": {
    "@pyreon/manifest": "workspace:*",
    "@pyreon/vitest-config": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
