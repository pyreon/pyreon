{
  "name": "@pyreon/runtime-server",
  "version": "0.1.0",
  "description": "SSR/SSG renderer for Pyreon — streaming HTML + static generation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/runtime-server"
  },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/runtime-server#readme",
  "bugs": { "url": "https://github.com/pyreon/pyreon/issues" },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --external @pyreon/core --external @pyreon/reactivity",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --watch --external @pyreon/core --external @pyreon/reactivity",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/reactivity": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
