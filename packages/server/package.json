{
  "name": "@pyreon/server",
  "version": "0.2.0",
  "description": "SSR handler, SSG prerender, and island architecture for Pyreon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/server#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./client": {
      "bun": "./src/client.ts",
      "import": "./lib/client.js",
      "types": "./lib/types/client.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pyreon/core": "^0.2.0",
    "@pyreon/head": "^0.2.0",
    "@pyreon/reactivity": "^0.2.0",
    "@pyreon/router": "^0.2.0",
    "@pyreon/runtime-dom": "^0.2.0",
    "@pyreon/runtime-server": "^0.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
