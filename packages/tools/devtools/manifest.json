{
  "manifest_version": 3,
  "name": "Pyreon DevTools",
  "version": "0.1.0",
  "description": "Chrome DevTools extension for the Pyreon UI framework",
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/pyreon-16.png",
    "32": "icons/pyreon-32.png",
    "48": "icons/pyreon-48.png",
    "128": "icons/pyreon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": ["content-script.js"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": []
}
