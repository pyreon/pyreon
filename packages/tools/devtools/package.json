{
  "name": "@pyreon/devtools",
  "version": "0.1.0",
  "description": "Chrome DevTools extension for the Pyreon UI framework — live component tree, click-to-highlight, inspector",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/tools/devtools#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/tools/devtools"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vl_rolldown_build && bun run scripts/sync-manifest.ts && bun run scripts/strip-cjs-decorators.ts",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "verify": "bun scripts/verify-extension.ts"
  },
  "devDependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@pyreon/runtime-dom": "workspace:*",
    "@types/chrome": "^0.1.38",
    "playwright": "^1.60.0"
  }
}
