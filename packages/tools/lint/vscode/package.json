{
  "name": "pyreon-lint",
  "displayName": "Pyreon Lint",
  "version": "0.13.1",
  "description": "Pyreon-specific lint rules for VS Code — signals, JSX, SSR, performance, reactivity",
  "categories": [
    "Linters"
  ],
  "keywords": [
    "jsx",
    "lint",
    "pyreon",
    "reactivity",
    "signals"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/tools/lint/vscode"
  },
  "publisher": "pyreon",
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Pyreon Lint",
      "properties": {
        "pyreonLint.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Pyreon Lint diagnostics"
        },
        "pyreonLint.preset": {
          "type": "string",
          "default": "recommended",
          "enum": [
            "recommended",
            "strict",
            "app",
            "lib"
          ],
          "description": "Lint preset to use"
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "engines": {
    "vscode": "^1.75.0"
  }
}
