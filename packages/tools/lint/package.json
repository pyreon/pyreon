{
  "name": "@pyreon/lint",
  "version": "0.44.0",
  "description": "Pyreon-specific linter — 56 rules for signals, JSX, SSR, performance, router, and architecture",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/tools/lint#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/tools/lint"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "bin": {
    "pyreon-lint": "./bin/pyreon-lint.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./cli": {
      "bun": "./src/cli.ts",
      "import": "./lib/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "lib",
    "src",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@oxc-project/types": "^0.138.0",
    "@pyreon/compiler": "workspace:*",
    "@pyreon/sized-map": "workspace:*",
    "oxc-parser": "^0.138.0"
  },
  "devDependencies": {
    "@pyreon/ansi": "workspace:*",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/vitest-config": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
