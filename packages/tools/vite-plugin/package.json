{
  "name": "@pyreon/vite-plugin",
  "version": "0.37.0",
  "description": "Vite plugin for Pyreon — .pyreon SFC support, HMR, compiler integration",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/tools/vite-plugin#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/tools/vite-plugin"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@pyreon/runtime-dom": "workspace:^",
    "vite": ">=8.0.0"
  },
  "dependencies": {
    "@pyreon/compiler": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "devDependencies": {
    "@pyreon/vitest-config": "workspace:*",
    "vite": "^8.0.16"
  },
  "publishConfig": {
    "access": "public"
  }
}
