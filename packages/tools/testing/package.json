{
  "name": "@pyreon/testing",
  "version": "0.50.0",
  "description": "Official testing utilities for Pyreon — Testing-Library-style render/screen/fireEvent plus reactive-native matchers",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/tools/testing#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/tools/testing"
  },
  "type": "module",
  "sideEffects": [
    "./lib/matchers.js",
    "./lib/vitest.js",
    "./src/matchers.ts",
    "./src/vitest.ts"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./matchers": {
      "bun": "./src/matchers.ts",
      "import": "./lib/matchers.js",
      "types": "./lib/matchers.d.ts"
    },
    "./vitest": {
      "bun": "./src/vitest.ts",
      "import": "./lib/vitest.js",
      "types": "./lib/vitest.d.ts"
    },
    "./form": {
      "bun": "./src/form.ts",
      "import": "./lib/form.js",
      "types": "./lib/form.d.ts"
    },
    "./ui": {
      "bun": "./src/ui.ts",
      "import": "./lib/ui.js",
      "types": "./lib/ui.d.ts"
    },
    "./router": {
      "bun": "./src/router.ts",
      "import": "./lib/router.js",
      "types": "./lib/router.d.ts"
    },
    "./store": {
      "bun": "./src/store.ts",
      "import": "./lib/store.js",
      "types": "./lib/store.d.ts"
    },
    "./i18n": {
      "bun": "./src/i18n.ts",
      "import": "./lib/i18n.js",
      "types": "./lib/i18n.d.ts"
    },
    "./toast": {
      "bun": "./src/toast.ts",
      "import": "./lib/toast.js",
      "types": "./lib/toast.d.ts"
    },
    "./query": {
      "bun": "./src/query.ts",
      "import": "./lib/query.js",
      "types": "./lib/query.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE",
    "src"
  ],
  "scripts": {
    "prepublish": "bun run build",
    "build": "bun run vl_rolldown_build",
    "build:watch": "bun run vl_rolldown_build-watch",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:browser": "vitest run --config ./vitest.browser.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/form": "workspace:^",
    "@pyreon/i18n": "workspace:^",
    "@pyreon/query": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/router": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/store": "workspace:^",
    "@pyreon/toast": "workspace:^",
    "@pyreon/ui-core": "workspace:^",
    "@testing-library/jest-dom": "^6.0.0",
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@pyreon/form": {
      "optional": true
    },
    "@pyreon/i18n": {
      "optional": true
    },
    "@pyreon/query": {
      "optional": true
    },
    "@pyreon/router": {
      "optional": true
    },
    "@pyreon/store": {
      "optional": true
    },
    "@pyreon/toast": {
      "optional": true
    },
    "@pyreon/ui-core": {
      "optional": true
    },
    "@testing-library/jest-dom": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pyreon/form": "workspace:*",
    "@pyreon/i18n": "workspace:*",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/query": "workspace:*",
    "@pyreon/router": "workspace:*",
    "@pyreon/store": "workspace:*",
    "@pyreon/toast": "workspace:*",
    "@pyreon/tsconfig": "workspace:*",
    "@pyreon/typescript": "workspace:^",
    "@pyreon/ui-core": "workspace:*",
    "@pyreon/vitest-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitus-labs/tools-rolldown": "^2.5.0"
  },
  "engines": {
    "node": ">= 22"
  },
  "publishConfig": {
    "access": "public"
  }
}
