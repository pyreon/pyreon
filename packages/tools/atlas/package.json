{
  "name": "@pyreon/atlas",
  "version": "0.0.0",
  "description": "AI-native component workbench for the Pyreon ecosystem — derives, verifies, and serves a machine-readable component catalog. Working name; rebrand pending.",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/tools/atlas#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/tools/atlas"
  },
  "type": "module",
  "private": true,
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "bin": {
    "atlas": "./bin/atlas.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./core": {
      "bun": "./src/core.ts",
      "import": "./lib/core.js",
      "types": "./lib/types/core.d.ts"
    },
    "./plugins": {
      "bun": "./src/plugins.ts",
      "import": "./lib/plugins.js",
      "types": "./lib/types/plugins.d.ts"
    },
    "./auto": {
      "bun": "./src/auto.ts",
      "import": "./lib/auto.js",
      "types": "./lib/types/auto.d.ts"
    },
    "./discover": {
      "bun": "./src/discover.ts",
      "import": "./lib/discover.js",
      "types": "./lib/types/discover.d.ts"
    },
    "./cli": {
      "bun": "./src/cli.ts",
      "import": "./lib/cli.js",
      "types": "./lib/types/cli.d.ts"
    },
    "./ui": {
      "bun": "./src/ui.ts",
      "import": "./lib/ui.js",
      "types": "./lib/types/ui.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "demo": "bun scripts/demo.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/elements": "workspace:*",
    "@pyreon/hooks": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@pyreon/rocketstyle": "workspace:*",
    "@pyreon/runtime-dom": "workspace:*",
    "@pyreon/styler": "workspace:*",
    "@pyreon/ui-core": "workspace:*",
    "@pyreon/unistyle": "workspace:*",
    "typescript": ">=5.0.0 <7.0.0"
  },
  "devDependencies": {
    "@pyreon/tsconfig": "workspace:*",
    "@pyreon/vitest-config": "workspace:*"
  }
}
