{
  "name": "@pyreon/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for Pyreon — .pyreon SFC support, HMR, compiler integration",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/pyreon/pyreon.git", "directory": "packages/vite-plugin" },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/vite-plugin#readme",
  "bugs": { "url": "https://github.com/pyreon/pyreon/issues" },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@pyreon/compiler": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
