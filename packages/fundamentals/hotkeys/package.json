{
  "name": "@pyreon/hotkeys",
  "version": "0.49.0",
  "description": "Reactive keyboard shortcut management for Pyreon — scope-aware, conflict detection",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/hotkeys#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/hotkeys"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "bench:keys": "NODE_ENV=production bun bench/hotkeys-bench.ts"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/vitest-config": "workspace:*",
    "@vitus-labs/tools-lint": "^2.6.3",
    "hotkeys-js": "^4.0.4",
    "mousetrap": "^1.6.5",
    "tinykeys": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
