{
  "name": "@pyreon/validate",
  "version": "0.38.0",
  "description": "Pyreon DX layer over Standard Schema \u2014 withField metadata, reactive parse, i18n-aware error formatting. Works with Zod, Valibot, ArkType, or any Standard Schema-compliant validator.",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/validate#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/validate"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "./src/server.ts",
    "./lib/server.js"
  ],
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./server": {
      "bun": "./src/server.ts",
      "import": "./lib/server.js",
      "types": "./lib/types/server.d.ts"
    },
    "./mini": {
      "bun": "./src/mini.ts",
      "import": "./lib/mini.js",
      "types": "./lib/types/mini.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "bench:validation": "bun bench/validation.ts",
    "bench:behavior": "bun bench/behavior.ts",
    "bench:compiled-verdict": "NODE_ENV=production bun bench/compiled-verdict.ts"
  },
  "devDependencies": {
    "@pyreon/compiler": "workspace:*",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/validation": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "@vitus-labs/tools-lint": "^2.6.3",
    "arktype": "^2.2.0",
    "valibot": "^1.4.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@pyreon/reactivity": "workspace:^"
  }
}
