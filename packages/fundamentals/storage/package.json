{
  "name": "@pyreon/storage",
  "version": "0.12.15",
  "description": "Reactive client-side storage for Pyreon — localStorage, sessionStorage, cookies, IndexedDB",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/storage#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/storage"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/reactivity": "workspace:^",
    "@vitus-labs/tools-lint": "^1.15.5",
    "bun-types": "^1.3.12"
  },
  "peerDependencies": {
    "@pyreon/reactivity": "workspace:^"
  }
}
