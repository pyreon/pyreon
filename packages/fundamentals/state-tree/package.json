{
  "name": "@pyreon/state-tree",
  "version": "0.48.0",
  "description": "Structured reactive state tree — composable models with snapshots, patches, and middleware",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/state-tree#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/state-tree"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./devtools": {
      "bun": "./src/devtools.ts",
      "import": "./lib/devtools.js",
      "types": "./lib/types/devtools.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "bench:mst": "NODE_ENV=production bun bench/state-tree-bench.ts"
  },
  "peerDependencies": {
    "@pyreon/reactivity": "workspace:^"
  },
  "dependencies": {
    "@pyreon/validation": "workspace:^"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/vitest-config": "workspace:*",
    "@vitus-labs/tools-lint": "^2.6.3",
    "arktype": "^2.2.3",
    "bun-types": "^1.3.14",
    "mobx": "^6.13.0",
    "mobx-state-tree": "^7.3.1",
    "valibot": "^1.4.1",
    "zod": "^4.4.3",
    "@pyreon/validate": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
