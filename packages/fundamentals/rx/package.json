{
  "name": "@pyreon/rx",
  "version": "0.43.0",
  "description": "Signal-aware reactive transforms — filter, map, sort, group, pipe for Pyreon signals",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/rx#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/rx"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "bench:rxjs": "NODE_ENV=production bun bench/rx-bench.ts"
  },
  "peerDependencies": {
    "@pyreon/reactivity": "workspace:^"
  },
  "devDependencies": {
    "@pyreon/manifest": "workspace:*",
    "@pyreon/typescript": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "rxjs": "^7.8.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
