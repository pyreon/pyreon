{
  "name": "@pyreon/dnd",
  "version": "0.11.0",
  "description": "Signal-driven drag and drop for Pyreon \u2014 wraps @atlaskit/pragmatic-drag-and-drop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/dnd"
  },
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.0",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.0.0",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.0.0"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "devDependencies": {
    "@pyreon/typescript": "workspace:^"
  }
}
