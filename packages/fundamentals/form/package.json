{
  "name": "@pyreon/form",
  "version": "0.30.0",
  "description": "Signal-based form management for Pyreon",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/form#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/form"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./devtools": {
      "bun": "./src/devtools.ts",
      "import": "./lib/devtools.js",
      "types": "./lib/types/devtools.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/vitest-config": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
