{
  "name": "@pyreon/rich-text",
  "version": "0.44.0",
  "description": "Reactive WYSIWYG rich-text editor for Pyreon — signal-backed layer over TipTap (ProseMirror); collaboration composes with @pyreon/sync",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/rich-text#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/rich-text"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "test:browser": "vitest run --config ./vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/test-utils": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitus-labs/tools-lint": "^2.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
