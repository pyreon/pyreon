{
  "name": "@pyreon/sync",
  "version": "0.47.0",
  "description": "Local-first CRDT-backed sync for signals — a synced signal is just a signal, so remote ops drive surgical fine-grained updates",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/sync#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/sync"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./yjs": {
      "bun": "./src/yjs.ts",
      "import": "./lib/yjs.js",
      "types": "./lib/types/yjs.d.ts"
    },
    "./server": {
      "bun": "./src/server.ts",
      "import": "./lib/server.js",
      "types": "./lib/types/server.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "peerDependencies": {
    "@pyreon/reactivity": "workspace:^"
  },
  "dependencies": {
    "ws": "^8.21.1",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@pyreon/core": "workspace:^",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "@types/ws": "^8.18.1",
    "@vitus-labs/tools-lint": "^2.6.3",
    "bun-types": "^1.3.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
