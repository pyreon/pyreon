{
  "name": "@pyreon/charts",
  "version": "0.46.0",
  "description": "Reactive ECharts bridge for Pyreon — lazy loading, signal-driven, Canvas by default",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/charts#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/charts"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./manual": {
      "bun": "./src/manual.ts",
      "import": "./lib/manual.js",
      "types": "./lib/types/manual.d.ts"
    },
    "./vite": {
      "bun": "./src/vite.ts",
      "import": "./lib/vite.js",
      "types": "./lib/types/vite.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "test:browser": "vitest run --config ./vitest.browser.config.ts",
    "bench": "NODE_ENV=production bun bench/wrapper-overhead.bench.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "echarts": ">=5.6.0"
  },
  "devDependencies": {
    "@pyreon/manifest": "workspace:*",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/test-utils": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "@vitest/browser-playwright": "^4.1.10",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.2",
    "happy-dom": "^20.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
