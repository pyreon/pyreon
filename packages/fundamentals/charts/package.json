{
  "name": "@pyreon/charts",
  "version": "0.11.3",
  "description": "Reactive ECharts bridge for Pyreon \u2014 lazy loading, signal-driven, Canvas by default",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/charts"
  },
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/charts#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./manual": {
      "bun": "./src/manual.ts",
      "import": "./lib/manual.js",
      "types": "./lib/types/manual.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "echarts": ">=5.6.0"
  },
  "devDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^",
    "echarts": "^6.0.0"
  }
}
