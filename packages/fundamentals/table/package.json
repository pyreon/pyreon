{
  "name": "@pyreon/table",
  "version": "0.45.0",
  "description": "Pyreon adapter for TanStack Table",
  "license": "MIT",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/fundamentals/table#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/table"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "bench:table": "NODE_ENV=production bun bench/table-rerender-bench.ts",
    "bench:table:wall": "NODE_ENV=production bun bench/table-bench.ts"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "dependencies": {
    "@tanstack/table-core": "^8.21.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/runtime-dom": "workspace:^",
    "@pyreon/vitest-config": "workspace:*",
    "@tanstack/react-table": "8.21.3",
    "bun-types": "^1.3.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
