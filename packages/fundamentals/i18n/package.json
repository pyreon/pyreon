{
  "name": "@pyreon/i18n",
  "version": "0.12.12",
  "description": "Reactive internationalization for Pyreon with async namespace loading",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/i18n#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/i18n"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./core": {
      "bun": "./src/core.ts",
      "import": "./lib/core.js",
      "types": "./lib/types/core.d.ts"
    },
    "./devtools": {
      "bun": "./src/devtools.ts",
      "import": "./lib/devtools.js",
      "types": "./lib/types/devtools.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^",
    "@pyreon/runtime-dom": "workspace:^"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  }
}
