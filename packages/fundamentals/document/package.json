{
  "name": "@pyreon/document",
  "version": "0.12.15",
  "description": "Universal document rendering for Pyreon — one template, every output format (HTML, PDF, DOCX, email, XLSX, Markdown, and more)",
  "homepage": "https://github.com/pyreon/pyreon/tree/main/packages/document#readme",
  "bugs": {
    "url": "https://github.com/pyreon/pyreon/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/pyreon.git",
    "directory": "packages/fundamentals/document"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@pyreon/core": "workspace:^",
    "@pyreon/manifest": "workspace:*",
    "@pyreon/reactivity": "workspace:^",
    "@types/pdfmake": "^0.3.2",
    "@vitus-labs/tools-lint": "^1.15.5",
    "docx": "^9.6.0",
    "exceljs": "^4.4.0",
    "pdfmake": "^0.3.7",
    "pptxgenjs": "^4.0.1"
  },
  "peerDependencies": {
    "@pyreon/core": "workspace:^",
    "@pyreon/reactivity": "workspace:^"
  },
  "optionalDependencies": {
    "docx": "^9.6.0",
    "exceljs": "^4.4.0",
    "pdfmake": "^0.3.7",
    "pptxgenjs": "^4.0.1"
  }
}
