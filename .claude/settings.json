{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(bun run:*)",
      "Bash(bun run test*)",
      "Bash(bun run --filter=*)",
      "Bash(bun install:*)",
      "Bash(bunx oxlint*)",
      "Bash(bunx oxfmt*)",
      "Bash(bunx tsc*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(gh pr checks*)",
      "Bash(gh pr view*)",

      "Bash(gh api*)",
      "Bash(bun run*)",
      "Bash(bun install*)",
      "Bash(bunx oxlint*)",
      "Bash(bunx oxfmt*)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(python3 *)",
      "Bash(sed *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/guard-main-push.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/guard-branch-name.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
