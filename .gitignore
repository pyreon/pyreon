node_modules
dist
lib
# `src/lib/` is always source code (template content, fixture content,
# app code), never package build output (which lives at `<pkg>/lib/`).
# Un-ignore universally so the bare `lib` rule above can't silently eat
# committed source files. This has bitten twice — PR #404 (template src/
# lib) and PR #411 (fixture src/lib) — collapsing all the per-path
# negations into one general rule.
!**/src/lib
!**/src/lib/**
analysis
.turbo
*.tsbuildinfo
.env
.env.local
.DS_Store
coverage
.next
.source
test-results
.vitest-attachments
**/__screenshots__
scripts/visual-test/current/*.png
scripts/visual-test/diffs/*.png

# Perf harness recordings — only `baseline-*.json` is committed; per-SHA
# recordings are artefacts of a run and don't belong in the tree.
perf-results/*.json
!perf-results/baseline-*.json

# AI context — auto-regenerated by @pyreon/vite-plugin on dev start
**/.pyreon/context.json

# Architecture review analysis artifacts (development only)
ANALYSIS_*.txt
ARCHITECTURAL_REVIEW*.md
ARCHITECTURE_FIX_PLAN.md
COMPLETION_REPORT.md
REVIEW_INDEX.md
00_READ_ME_FIRST.md
IMPLEMENTATION_GUIDE.md
QUICK_REFERENCE.md

# Claude worktrees (local development only)
.claude/worktrees/
.claude/scheduled_tasks.lock
