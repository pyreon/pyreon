node_modules
dist
lib
# Template + example src/lib/ directories are real source content
# (scaffolded into user projects, or committed as runtime test fixtures),
# NOT package build output. Keep them tracked even though the bare `lib`
# rule above would otherwise match. The `examples/*/src/lib` negation
# specifically un-ignores the create-pyreon-app Playwright fixtures
# (`examples/cpa-pw-*/src/lib/{auth,db,posts}.ts`).
!packages/zero/create-zero/templates/*/src/lib
!packages/zero/create-zero/templates/*/src/lib/**
!examples/*/src/lib
!examples/*/src/lib/**
analysis
.turbo
*.tsbuildinfo
.env
.env.local
.DS_Store
coverage
.next
.source
test-results
.vitest-attachments
**/__screenshots__
scripts/visual-test/current/*.png
scripts/visual-test/diffs/*.png

# Perf harness recordings — only `baseline-*.json` is committed; per-SHA
# recordings are artefacts of a run and don't belong in the tree.
perf-results/*.json
!perf-results/baseline-*.json

# AI context — auto-regenerated by @pyreon/vite-plugin on dev start
**/.pyreon/context.json

# Architecture review analysis artifacts (development only)
ANALYSIS_*.txt
ARCHITECTURAL_REVIEW*.md
ARCHITECTURE_FIX_PLAN.md
COMPLETION_REPORT.md
REVIEW_INDEX.md
00_READ_ME_FIRST.md
IMPLEMENTATION_GUIDE.md
QUICK_REFERENCE.md

# Claude worktrees (local development only)
.claude/worktrees/
.claude/scheduled_tasks.lock
