node_modules
dist
lib
# Template + example src/lib/ directories are real source content
# (scaffolded into user projects, or committed as runtime test fixtures),
# NOT package build output. Keep them tracked even though the bare `lib`
# rule above would otherwise match. The `examples/*/src/lib` negation
# specifically un-ignores the create-pyreon-app Playwright fixtures
# (`examples/cpa-pw-*/src/lib/{auth,db,posts}.ts`).
!packages/zero/create-zero/templates/*/src/lib
!packages/zero/create-zero/templates/*/src/lib/**
!packages/zero/create-zero/templates/**/src/lib
!packages/zero/create-zero/templates/**/src/lib/**
!examples/*/src/lib
!examples/*/src/lib/**
analysis
# @pyreon/mcp bundled content snapshot — generated at build time by
# scripts/copy-content.ts (shipped in the tarball via `files`, not committed).
packages/tools/mcp/content
.turbo
*.tsbuildinfo
.env
.env.local
.DS_Store
coverage
.next
.source
test-results
.vitest-attachments
**/__screenshots__
scripts/visual-test/current/*.png
scripts/visual-test/diffs/*.png

# Perf harness recordings — only `baseline-*.json` is committed; per-SHA
# recordings are artefacts of a run and don't belong in the tree.
perf-results/*.json
!perf-results/baseline-*.json

# AI context — auto-regenerated by @pyreon/vite-plugin on dev start
**/.pyreon/context.json

# @pyreon/compiler Rust native binary — built locally by
# packages/core/compiler/scripts/build-native.ts during `bun install`
# (when cargo is available). Pre-built per-platform binaries ship as
# separate npm packages once Phase 4 of the Rust roadmap lands; until
# then this is a build artifact, never committed.
packages/core/compiler/native/pyreon-compiler.node
packages/core/compiler/native/target/

# Architecture review analysis artifacts (development only)
ANALYSIS_*.txt
ARCHITECTURAL_REVIEW*.md
ARCHITECTURE_FIX_PLAN.md
COMPLETION_REPORT.md
REVIEW_INDEX.md
00_READ_ME_FIRST.md
IMPLEMENTATION_GUIDE.md
QUICK_REFERENCE.md

# Claude worktrees (local development only)
.claude/worktrees/
.claude/scheduled_tasks.lock

# Doc-example typecheck cache (scripts/check-doc-examples.ts) — extracts
# fenced code blocks here, then runs `tsc --noEmit`. Regenerated every run.
.cache/

# Incremental-bootstrap content-hash manifest (scripts/bootstrap.ts)
.bootstrap-cache.json

# Vercel Build Output API v3 tree. The vercel adapter must write it at the
# PROJECT ROOT (not under dist/) — that is the only path Vercel auto-detects.
# So the `dist` rule above does NOT cover it; a local `verify-modes` or
# `zero build --adapter vercel` would otherwise leave it untracked.
.vercel/
