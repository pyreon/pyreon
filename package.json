{
  "name": "pyreon",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='*' test",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "bun run --filter='*' typecheck",
    "size": "bun run scripts/bundle-size.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitus-labs/tools-lint": "^1.11.0",
    "@vitus-labs/tools-rolldown": "^1.11.0",
    "@vitus-labs/tools-typescript": "^1.11.0",
    "@vitus-labs/tools-vitest": "^1.11.0",
    "happy-dom": "^20.8.3",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
