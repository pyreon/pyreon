{
  "name": "pyreon",
  "private": true,
  "workspaces": [
    "packages/*/*",
    "examples/*",
    "docs"
  ],
  "scripts": {
    "postinstall": "bun scripts/bootstrap.ts",
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='*' test",
    "test:browser": "bun run --filter='*' test:browser",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:browser-smoke": "bun scripts/check-browser-smoke.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "bun run --filter='*' typecheck",
    "size": "bun run scripts/bundle-size.ts",
    "gen-docs": "bun scripts/gen-docs.ts",
    "bench:reactivity": "bun scripts/bench/core/reactivity.ts",
    "bench:compiler": "bun scripts/bench/core/compiler.ts",
    "bench:router": "bun scripts/bench/core/router.ts",
    "bench:ssr": "bun scripts/bench/core/runtime-server.ts",
    "bench:head": "bun scripts/bench/core/head.ts",
    "bench:server": "bun scripts/bench/core/server.ts",
    "bench:dom": "bun scripts/bench/dom.ts",
    "bench:all": "bun scripts/bench/run-all.ts",
    "bench:compare": "bun scripts/bench/compare.ts",
    "bench:bundle-size": "bun scripts/bench/bundle-size.ts",
    "perf:record": "bun scripts/perf/record.ts",
    "perf:diff": "bun scripts/perf/diff.ts",
    "test:e2e": "bunx playwright test --project=playground --project=ssr-showcase --project=fundamentals",
    "test:e2e:ui-regression": "bunx playwright test --config=playwright.ui-regression.config.ts",
    "test:e2e:compat": "bunx playwright test --config=playwright.compat-layers.config.ts",
    "test:e2e:app-showcase": "bunx playwright test --config=playwright.app-showcase.config.ts",
    "test:e2e:cpa": "bunx playwright test --config=playwright.cpa.config.ts",
    "visual-test:capture": "bunx playwright test --project=visual",
    "visual-test:diff": "bun scripts/visual-test/diff.ts",
    "visual-test:report": "bun scripts/visual-test/report.ts",
    "visual-test:update": "bun scripts/visual-test/update.ts",
    "coverage": "bun scripts/check-coverage.ts",
    "test:coverage": "bun scripts/check-coverage.ts",
    "audit-types": "bun scripts/audit-types.ts",
    "verify-modes": "bun scripts/verify-modes.ts",
    "scaffold-smoke": "bun scripts/scaffold-smoke.ts",
    "scaffold-cpa-fixtures": "bun scripts/scaffold-cpa-fixtures.ts",
    "check-bundle-budgets": "bun scripts/check-bundle-budgets.ts",
    "check-distribution": "bun scripts/check-distribution.ts",
    "check-doc-claims": "bun scripts/check-doc-claims.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@preact/signals-core": "^1.14.1",
    "@swc/core": "^1.15.30",
    "@tanstack/react-router": "^1.168.23",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@unhead/ssr": "^2.1.13",
    "@unhead/vue": "^2.1.13",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitus-labs/tools-rolldown": "^2.3.0",
    "@vitus-labs/tools-typescript": "^1.15.5",
    "@vitus-labs/tools-vitest": "^1.15.5",
    "esbuild": "^0.27.7",
    "find-my-way": "^9.5.0",
    "happy-dom": "^20.9.0",
    "hono": "^4.12.14",
    "next": "^16.2.4",
    "oxc-parser": "^0.123.0",
    "oxc-transform": "^0.123.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.61.0",
    "playwright": "^1.59.1",
    "radix3": "^1.1.2",
    "react-router": "^7.14.2",
    "solid-js": "^1.9.12",
    "typescript": "^6.0.3",
    "unhead": "^2.1.13",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-router": "^5.0.4"
  }
}
