{
  "name": "pyreon",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='./packages/*' test",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "bun run --filter='*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@vitus-labs/tools-lint": "^1.11.0",
    "@vitus-labs/tools-rolldown": "^1.11.0",
    "@vitus-labs/tools-typescript": "^1.11.0",
    "@vitus-labs/tools-vitest": "^1.11.0",
    "happy-dom": "^20.8.3",
    "playwright": "^1.58.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
