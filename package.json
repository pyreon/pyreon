{
  "name": "pyreon",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='*' test",
    "test:watch": "vitest",
    "lint": "bun run --filter='*' lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "bun run --filter='*' typecheck",
    "size": "bun run scripts/bundle-size.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitus-labs/tools-lint": "^1.13.0",
    "@vitus-labs/tools-rolldown": "^1.13.0",
    "@vitus-labs/tools-typescript": "^1.13.0",
    "@vitus-labs/tools-vitest": "^1.13.0",
    "happy-dom": "^20.8.4",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
