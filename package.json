{
  "name": "pyreon",
  "private": true,
  "workspaces": [
    "packages/*/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='*' test",
    "test:watch": "vitest",
    "lint": "bun run --filter='*' lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "bun run --filter='*' typecheck",
    "size": "bun run scripts/bundle-size.ts",
    "bench:reactivity": "bun scripts/bench/core/reactivity.ts",
    "bench:compiler": "bun scripts/bench/core/compiler.ts",
    "bench:router": "bun scripts/bench/core/router.ts",
    "bench:ssr": "bun scripts/bench/core/runtime-server.ts",
    "bench:head": "bun scripts/bench/core/head.ts",
    "bench:server": "bun scripts/bench/core/server.ts",
    "bench:dom": "bun scripts/bench/dom.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@biomejs/biome": "^2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "@preact/signals-core": "^1.14.0",
    "@swc/core": "^1.15.21",
    "@tanstack/react-router": "^1.168.3",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@unhead/ssr": "^2.1.12",
    "@unhead/vue": "^2.1.12",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitus-labs/tools-lint": "^1.15.4",
    "@vitus-labs/tools-rolldown": "^1.15.4",
    "@vitus-labs/tools-typescript": "^1.15.4",
    "@vitus-labs/tools-vitest": "^1.15.4",
    "esbuild": "^0.27.4",
    "find-my-way": "^9.5.0",
    "happy-dom": "^20.8.7",
    "hono": "^4.12.9",
    "next": "^16.2.1",
    "oxc-transform": "^0.121.0",
    "playwright": "^1.58.2",
    "radix3": "^1.1.2",
    "react-router": "^7.13.2",
    "solid-js": "^1.9.11",
    "typescript": "^6.0.2",
    "unhead": "^2.1.12",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "vue-router": "^5.0.4"
  }
}
