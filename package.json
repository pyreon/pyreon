{
  "name": "pyreon",
  "private": true,
  "workspaces": [
    "packages/*/*",
    "packages/core/compiler/npm/*",
    "examples/*",
    "docs"
  ],
  "scripts": {
    "postinstall": "bun scripts/bootstrap.ts",
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun run --filter='*' test",
    "test:browser": "bun run --filter='*' test:browser",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:browser-smoke": "bun scripts/check-browser-smoke.ts",
    "lint:pyreon": "bun packages/tools/cli/src/index.ts doctor --only lint --ci",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "bun run --filter='*' typecheck",
    "size": "bun run scripts/bundle-size.ts",
    "gen-docs": "bun scripts/gen-docs.ts",
    "bench:reactivity": "bun scripts/bench/core/reactivity.ts",
    "bench:compiler": "bun scripts/bench/core/compiler.ts",
    "bench:router": "bun scripts/bench/core/router.ts",
    "bench:ssr": "bun scripts/bench/core/runtime-server.ts",
    "bench:head": "bun scripts/bench/core/head.ts",
    "bench:server": "bun scripts/bench/core/server.ts",
    "bench:dom": "bun scripts/bench/dom.ts",
    "bench:all": "bun scripts/bench/run-all.ts",
    "bench:compare": "bun scripts/bench/compare.ts",
    "bench:bundle-size": "bun scripts/bench/bundle-size.ts",
    "perf:record": "bun scripts/perf/record.ts",
    "perf:diff": "bun scripts/perf/diff.ts",
    "perf:leak-audit": "bun scripts/leak-audit.ts",
    "perf:leak-sweep": "bun scripts/leak-sweep.ts",
    "test:e2e": "bunx playwright test --project=playground --project=ssr-showcase --project=fundamentals",
    "test:e2e:ui-regression": "bunx playwright test --config=e2e-configs/ui-regression.config.ts",
    "test:e2e:compat": "bunx playwright test --config=e2e-configs/compat-layers.config.ts",
    "test:e2e:app-showcase": "bunx playwright test --config=e2e-configs/app-showcase.config.ts",
    "test:e2e:islands": "bunx playwright test --config=e2e-configs/islands-showcase.config.ts",
    "test:e2e:ssr-node": "bunx playwright test --config=e2e-configs/ssr-node.config.ts",
    "test:e2e:isr-node": "bunx playwright test --config=e2e-configs/isr-node.config.ts",
    "test:e2e:ssg-subpath": "bunx playwright test --config=e2e-configs/ssg-subpath.config.ts",
    "test:e2e:ssg-i18n": "bunx playwright test --config=e2e-configs/ssg-i18n.config.ts",
    "test:e2e:ssg-i18n-prefix": "bunx playwright test --config=e2e-configs/ssg-i18n-prefix.config.ts",
    "test:e2e:zero-islands": "bunx playwright test --config=e2e-configs/zero-islands.config.ts",
    "test:e2e:zero-hmr": "bunx playwright test --config=e2e-configs/zero-hmr.config.ts",
    "test:e2e:cpa": "bunx playwright test --config=e2e-configs/cpa.config.ts",
    "test:e2e:perf-dashboard": "bunx playwright test --config=e2e-configs/perf-dashboard.config.ts",
    "test:e2e:native-todomvc-web": "bunx playwright test --config=e2e-configs/native-todomvc-web.config.ts",
    "test:e2e:native-router-demo-web": "bunx playwright test --config=e2e-configs/native-router-demo-web.config.ts",
    "visual-test:capture": "bunx playwright test --project=visual",
    "visual-test:diff": "bun scripts/visual-test/diff.ts",
    "visual-test:report": "bun scripts/visual-test/report.ts",
    "visual-test:update": "bun scripts/visual-test/update.ts",
    "coverage": "bun scripts/check-coverage.ts",
    "coverage:floor": "bun scripts/check-coverage.ts --floor-only",
    "test:coverage": "bun scripts/check-coverage.ts",
    "audit-leak-classes": "bun scripts/audit-leak-classes.ts",
    "audit-types": "bun scripts/audit-types.ts",
    "verify-modes": "bun scripts/verify-modes.ts",
    "scaffold-smoke": "bun scripts/scaffold-smoke.ts",
    "scaffold-cpa-fixtures": "bun scripts/scaffold-cpa-fixtures.ts",
    "check-bundle-budgets": "bun scripts/check-bundle-budgets.ts",
    "check-changeset-required": "bun scripts/check-changeset-required.ts",
    "check-client-bundle-node-imports": "bun scripts/check-client-bundle-node-imports.ts",
    "check-distribution": "bun scripts/check-distribution.ts",
    "check-doc-claims": "bun scripts/check-doc-claims.ts",
    "check-lint-ratchet": "bun scripts/check-lint-ratchet.ts",
    "check-manifest-depth": "bun scripts/check-manifest-depth.ts",
    "check-mcp-docs": "bun scripts/check-mcp-docs.ts",
    "check-release-readiness": "bun scripts/check-release-readiness.ts",
    "validate-fast": "bun scripts/validate-fast.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && bun scripts/cap-version-bumps.ts",
    "release": "bun run --filter='./packages/*/*' build && bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@pyreon/playwright-config": "workspace:*",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "@preact/signals-core": "^1.14.2",
    "@swc/core": "^1.15.40",
    "@tanstack/react-router": "^1.170.10",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@unhead/ssr": "^3.1.1",
    "@unhead/vue": "^3.1.1",
    "@vitest/browser": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitus-labs/tools-rolldown": "^2.5.0",
    "@vitus-labs/tools-typescript": "^2.5.0",
    "@vitus-labs/tools-vitest": "^2.5.0",
    "esbuild": "^0.28.0",
    "find-my-way": "^9.6.0",
    "happy-dom": "^20.9.0",
    "hono": "^4.12.23",
    "next": "^16.2.6",
    "oxc-parser": "^0.133.0",
    "oxc-transform": "^0.133.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "playwright": "^1.60.0",
    "radix3": "^1.1.2",
    "react-router": "^7.16.0",
    "solid-js": "^1.9.13",
    "typescript": "^6.0.3",
    "unhead": "^3.1.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-router": "^5.1.0"
  },
  "overrides": {
    "@codemirror/view": "6.43.0",
    "zod": "4.4.3"
  },
  "dependencies": {
    "@vitest/browser-playwright": "^4.1.8"
  }
}
