{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "jsx-a11y", "promise", "node", "vitest"],
  "categories": {
    "correctness": "warn"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ],
    "no-shadow": "warn",
    "no-empty": "warn",
    "no-console": "warn",
    "no-template-curly-in-string": "warn",
    "no-debugger": "error",
    "typescript/no-non-null-assertion": "warn",
    "import/no-duplicates": "warn",
    "jsx-a11y/control-has-associated-label": "off",
    "jsx-a11y/label-has-associated-control": "off",
    "oxc/no-accumulating-spread": "warn",
    "oxc/no-map-spread": "warn",
    "vitest/require-mock-type-parameters": "off",
    "vitest/expect-expect": "off",
    "vitest/no-conditional-expect": "off",
    "vitest/require-to-throw-message": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "no-console": "off",
        "no-empty": "off",
        "no-shadow": "off",
        "no-template-curly-in-string": "off",
        "typescript/no-non-null-assertion": "off",
        "no-unused-vars": "off"
      }
    },
    {
      "files": [
        "packages/core/reactivity/src/debug.ts",
        "packages/core/reactivity/src/effect.ts",
        "packages/core/reactivity/src/scope.ts",
        "packages/core/runtime-dom/src/devtools.ts",
        "packages/core/runtime-dom/src/hydrate.ts",
        "packages/core/runtime-dom/src/hydration-debug.ts",
        "packages/core/runtime-dom/src/mount.ts",
        "packages/core/runtime-dom/src/nodes.ts",
        "packages/core/runtime-dom/src/props.ts",
        "packages/core/runtime-dom/src/transition.ts",
        "packages/core/runtime-server/src/index.ts",
        "packages/core/server/src/handler.ts",
        "packages/core/server/src/client.ts",
        "examples/benchmark/**/*.ts",
        "scripts/**/*.ts",
        "packages/tools/cli/src/**",
        "packages/tools/mcp/src/**",
        "packages/tools/devtools/scripts/**/*.ts",
        "packages/tools/lint/src/cli.ts",
        "packages/tools/lint/src/watcher.ts"
      ],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["packages/tools/devtools/scripts/generate-icons.ts"],
      "rules": {
        "typescript/no-non-null-assertion": "off"
      }
    },
    {
      "files": ["packages/fundamentals/flow/src/**", "packages/fundamentals/code/src/**"],
      "rules": {
        "jsx-a11y/alt-text": "off",
        "jsx-a11y/prefer-tag-over-role": "off",
        "jsx-a11y/no-static-element-interactions": "off",
        "jsx-a11y/click-events-have-key-events": "off",
        "jsx-a11y/no-noninteractive-element-interactions": "off",
        "jsx-a11y/no-noninteractive-tabindex": "off",
        "jsx-a11y/no-noninteractive-element-to-interactive-role": "off"
      }
    },
    {
      "files": ["packages/tools/mcp/src/api-reference.ts"],
      "rules": {
        "no-useless-escape": "off",
        "no-template-curly-in-string": "off"
      }
    },
    {
      "files": ["packages/core/compiler/src/jsx.ts"],
      "rules": {
        "no-shadow": "off"
      }
    }
  ],
  "settings": {
    "jsx-a11y": {
      "polymorphicPropName": null,
      "components": {},
      "attributes": {}
    }
  },
  "env": {
    "builtin": true
  },
  "globals": {
    "Bun": "readonly",
    "describe": "readonly",
    "test": "readonly",
    "it": "readonly",
    "expect": "readonly",
    "vi": "readonly",
    "beforeEach": "readonly",
    "afterEach": "readonly",
    "beforeAll": "readonly",
    "afterAll": "readonly"
  },
  "ignorePatterns": ["dist", "lib", "node_modules", ".turbo", "e2e", "tests/browser", "templates"]
}
