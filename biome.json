{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "extends": ["@vitus-labs/tools-lint/biome"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/lib",
      "!**/node_modules",
      "!**/.turbo",
      "!e2e",
      "!tests/browser",
      "!apps",
      "!scripts"
    ]
  },
  "formatter": {
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    },
    "globals": [
      "describe",
      "test",
      "it",
      "expect",
      "vi",
      "beforeEach",
      "afterEach",
      "beforeAll",
      "afterAll"
    ]
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "noUnusedPrivateClassMembers": "warn",
        "useHookAtTopLevel": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn"
      },
      "suspicious": {
        "noEmptyBlockStatements": "warn",
        "noTemplateCurlyInString": "warn",
        "noConsole": "warn",
        "useIterableCallbackReturn": "warn"
      },
      "nursery": {
        "noShadow": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConsistentArrayType": "warn"
      }
    }
  }
}
