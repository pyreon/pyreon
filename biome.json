{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "extends": ["@vitus-labs/tools-lint/biome"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/lib",
      "!**/node_modules",
      "!**/.turbo",
      "!e2e",
      "!tests/browser",
      "!apps",
      "!scripts"
    ]
  },
  "formatter": {
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    },
    "globals": [
      "describe",
      "test",
      "it",
      "expect",
      "vi",
      "beforeEach",
      "afterEach",
      "beforeAll",
      "afterAll"
    ]
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "noUnusedPrivateClassMembers": "warn",
        "useHookAtTopLevel": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn"
      },
      "suspicious": {
        "noEmptyBlockStatements": "warn",
        "noTemplateCurlyInString": "warn",
        "noConsole": "warn",
        "useIterableCallbackReturn": "warn"
      },
      "nursery": {
        "noShadow": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConsistentArrayType": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "noEmptyBlockStatements": "off",
            "noTemplateCurlyInString": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "nursery": {
            "noShadow": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/reactivity/src/debug.ts",
        "packages/reactivity/src/effect.ts",
        "packages/reactivity/src/scope.ts",
        "packages/runtime-dom/src/devtools.ts",
        "packages/runtime-dom/src/hydrate.ts",
        "packages/runtime-dom/src/hydration-debug.ts",
        "packages/runtime-dom/src/mount.ts",
        "packages/runtime-dom/src/nodes.ts",
        "packages/runtime-dom/src/props.ts",
        "packages/runtime-dom/src/transition.ts",
        "packages/server/src/client.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
