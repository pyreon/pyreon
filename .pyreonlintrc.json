{
  "$schema": "./packages/tools/lint/schema/pyreonlintrc.schema.json",
  "preset": "recommended",
  "rules": {
    "pyreon/no-window-in-ssr": [
      "error",
      {
        "exemptPaths": [
          "packages/core/runtime-dom/",
          "packages/core/compiler/",
          "-compat/",
          "packages/tools/devtools/",
          "packages/internals/perf-harness/",
          "packages/internals/test-utils/",
          "__tests__/",
          ".test."
        ]
      }
    ],
    "pyreon/no-unbatched-updates": [
      "warn",
      {
        "exemptPaths": ["__tests__/", ".test."]
      }
    ],
    "pyreon/no-raw-addeventlistener": [
      "info",
      {
        "exemptPaths": [
          "packages/core/runtime-dom/",
          "packages/fundamentals/hooks/",
          "packages/fundamentals/storage/",
          "packages/core/router/",
          "packages/tools/devtools/",
          "packages/internals/perf-harness/",
          "packages/ui-system/elements/src/Overlay/"
        ]
      }
    ],
    "pyreon/no-raw-setinterval": [
      "info",
      {
        "exemptPaths": [
          "packages/core/runtime-dom/",
          "packages/fundamentals/hooks/",
          "packages/core/router/"
        ]
      }
    ],
    "pyreon/no-imperative-effect-on-create": [
      "warn",
      {
        "exemptPaths": [
          "packages/fundamentals/hooks/",
          "packages/fundamentals/rx/",
          "__tests__/",
          ".test."
        ]
      }
    ],
    "pyreon/no-process-dev-gate": [
      "error",
      {
        "exemptPaths": [
          "packages/zero/",
          "packages/core/server/",
          "packages/core/runtime-server/",
          "packages/tools/vite-plugin/",
          "packages/tools/cli/",
          "packages/tools/lint/",
          "packages/tools/mcp/",
          "packages/tools/storybook/",
          "packages/tools/typescript/",
          "scripts/"
        ]
      }
    ],
    "pyreon/dev-guard-warnings": [
      "error",
      {
        "exemptPaths": [
          "packages/zero/",
          "packages/core/server/",
          "packages/core/runtime-server/",
          "packages/tools/vite-plugin/",
          "packages/tools/cli/",
          "packages/tools/lint/",
          "packages/tools/mcp/",
          "packages/tools/storybook/",
          "packages/tools/typescript/",
          "packages/native/cli/",
          "packages/core/runtime-dom/src/hydration-debug.ts",
          "-compat/",
          "scripts/",
          "examples/"
        ]
      }
    ],
    "pyreon/no-bare-signal-in-jsx": [
      "error",
      {
        "exemptPaths": ["__tests__/", ".test."]
      }
    ],
    "pyreon/no-module-signal-in-server-package": [
      "error",
      {
        "exemptPaths": [
          "packages/zero/zero/src/i18n-routing.ts",
          "packages/zero/zero/src/theme.tsx"
        ]
      }
    ],
    "pyreon/prefer-isserver": [
      "warn",
      {
        "exemptPaths": [
          "packages/core/head/src/dom.ts",
          "packages/fundamentals/toast/src/toaster.tsx",
          "packages/fundamentals/virtual/src/use-window-virtualizer.ts",
          "packages/ui-system/elements/src/Overlay/positioning.ts",
          "packages/ui-system/elements/src/Portal/component.tsx",
          "packages/ui-system/styler/src/sheet.ts"
        ]
      }
    ]
  }
}
