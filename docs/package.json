{
  "name": "@pyreon/docs",
  "version": "0.0.1",
  "private": true,
  "description": "Pyreon's documentation site, built with @pyreon/zero + @pyreon/zero-content. Dogfoods the framework end-to-end.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "gen": "bun scripts/gen-all.ts",
    "gen:check": "bun scripts/check-generated-fresh.ts"
  },
  "dependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/flow": "workspace:*",
    "@pyreon/form": "workspace:*",
    "@pyreon/head": "workspace:*",
    "@pyreon/hotkeys": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@pyreon/router": "workspace:*",
    "@pyreon/runtime-dom": "workspace:*",
    "@pyreon/runtime-server": "workspace:*",
    "@pyreon/server": "workspace:*",
    "@pyreon/storage": "workspace:*",
    "@pyreon/sync": "workspace:*",
    "@pyreon/toast": "workspace:*",
    "@pyreon/virtual": "workspace:*",
    "@pyreon/vite-plugin": "workspace:*",
    "@pyreon/zero": "workspace:*",
    "@pyreon/zero-content": "workspace:*"
  },
  "devDependencies": {
    "@pyreon/typescript": "workspace:*",
    "@types/bun": "^1.3.14",
    "beasties": "^0.4.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
