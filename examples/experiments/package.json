{
  "name": "@pyreon/experiments",
  "version": "0.1.11",
  "private": true,
  "description": "Architectural experiments parent — see README.md and the open-work tracker at .claude/plans/open-work-2026-q3.md.",
  "type": "module",
  "scripts": {
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "echo 'experiment browser tests are opt-in — run via test:browser:<experiment> (e.g. test:browser:e2)'",
    "test:browser:e2": "vitest run --config ./vitest.browser.config.ts e2-static-rocketstyle",
    "test:browser:e2-probe": "vitest run --config ./vitest.browser.config.ts probe-resolves",
    "test:browser:e2-probe-element": "vitest run --config ./vitest.browser.config.ts probe-element-resolves",
    "build": "echo 'no build — experiments package is documentation + result archives'"
  },
  "dependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/elements": "workspace:*",
    "@pyreon/perf-harness": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@pyreon/runtime-dom": "workspace:*",
    "@pyreon/styler": "workspace:*",
    "@pyreon/ui-components": "workspace:*",
    "@pyreon/ui-core": "workspace:*",
    "@pyreon/ui-theme": "workspace:*"
  },
  "devDependencies": {
    "@pyreon/test-utils": "workspace:*",
    "@pyreon/vite-plugin": "workspace:*",
    "@pyreon/vitest-config": "workspace:*",
    "@vitest/browser-playwright": "^4.1.7",
    "oxc-parser": "^0.133.0",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
