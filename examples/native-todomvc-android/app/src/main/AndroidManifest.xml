<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest for the Pyreon TodoMVC Android reference.

  Minimal single-activity Compose app. `MainActivity` calls
  `setContent { TodoApp() }` where `TodoApp` is the compiler-emitted
  Composable from `../kotlin/com/pyreon/generated/TodoApp.kt`.

  Mirrors the iOS host's structural simplicity:
    - iOS:     SwiftUI @main App + WindowGroup { ContentView() }
    - Android: AndroidManifest + MainActivity.setContent { TodoApp() }
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:label="PyreonTodoMVC"
        android:allowBackup="true">
        <activity
            android:name="com.pyreon.MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
