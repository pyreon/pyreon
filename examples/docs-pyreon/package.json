{
  "name": "@pyreon/example-docs-pyreon",
  "version": "0.0.21",
  "private": true,
  "description": "Pyreon's documentation site, built with Pyreon itself. Dogfooding @pyreon/zero + @pyreon/vite-plugin + a custom markdown-to-Pyreon-JSX compiler.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@pyreon/router": "workspace:*",
    "@pyreon/runtime-dom": "workspace:*",
    "@pyreon/server": "workspace:*",
    "@pyreon/vite-plugin": "workspace:*",
    "@pyreon/zero": "workspace:*",
    "@pyreon/zero-content": "workspace:*"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.3.0",
    "markdown-it-anchor": "^9.2.1",
    "shiki": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  }
