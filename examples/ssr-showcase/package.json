{
  "name": "@pyreon/ssr-showcase",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:subpath": "vite build --config vite.config.subpath.ts",
    "build:i18n": "vite build --config vite.config.i18n.ts",
    "build:i18n-prefix": "vite build --config vite.config.i18n-prefix.ts",
    "build:islands": "vite build --config vite.config.islands.ts",
    "preview": "vite preview",
    "preview:subpath": "vite preview --config vite.config.subpath.ts",
    "preview:i18n": "vite preview --config vite.config.i18n.ts",
    "preview:i18n-prefix": "vite preview --config vite.config.i18n-prefix.ts",
    "preview:islands": "vite preview --config vite.config.islands.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@pyreon/coolgrid": "workspace:*",
    "@pyreon/core": "workspace:*",
    "@pyreon/elements": "workspace:*",
    "@pyreon/head": "workspace:*",
    "@pyreon/hooks": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@pyreon/rocketstyle": "workspace:*",
    "@pyreon/router": "workspace:*",
    "@pyreon/runtime-dom": "workspace:*",
    "@pyreon/styler": "workspace:*",
    "@pyreon/ui-core": "workspace:*",
    "@pyreon/unistyle": "workspace:*",
    "@pyreon/zero": "workspace:*"
  },
  "devDependencies": {
    "@pyreon/vite-plugin": "workspace:*",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
