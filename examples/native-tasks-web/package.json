{
  "name": "@pyreon/example-native-tasks-web",
  "version": "0.50.1",
  "private": true,
  "description": "PRIVATE / EXPERIMENTAL — Tasks showcase rendered on WEB via @pyreon/primitives runtime. Sibling host for the canonical TasksApp.tsx source from native-tasks/. Closes Gap 5 (web host shell for the tasks showcase).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run assets && vite",
    "build": "bun run assets && vite build",
    "preview": "vite preview",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "assets": "bun ../../packages/native/cli/src/cli.ts assets --target=web --source=../native-tasks/assets --out=public"
  },
  "dependencies": {
    "@pyreon/core": "workspace:*",
    "@pyreon/form": "workspace:*",
    "@pyreon/hooks": "workspace:*",
    "@pyreon/primitives": "workspace:*",
    "@pyreon/reactivity": "workspace:*",
    "@pyreon/router": "workspace:*",
    "@pyreon/runtime-dom": "workspace:*",
    "@pyreon/store": "workspace:*"
  },
  "devDependencies": {
    "@pyreon/tsconfig": "workspace:*",
    "@pyreon/vite-plugin": "workspace:*",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
