{
  "extends": "@pyreon/tsconfig/example.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "customConditions": [
      "bun"
    ],
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "src"
  ]
}
